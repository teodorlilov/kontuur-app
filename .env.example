# Supabase — safe to expose publicly, designed for client-side use
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Supabase service role — server only, never prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — server only, never prefix with NEXT_PUBLIC_
ANTHROPIC_API_KEY=

# Meta (Phase 2 — not needed in Phase 1)
META_APP_ID=
META_APP_SECRET=

# Resend — server only
RESEND_API_KEY=
RESEND_FROM_EMAIL=    # From address for approval emails (e.g. hello@youragency.com)

# App URL — safe to expose publicly
NEXT_PUBLIC_APP_URL=

# Cron job secret — server only, used to authenticate Vercel cron calls
CRON_SECRET=

# Jina AI Reader — server only, used to fetch website content for research sources
# Free without a key (20 RPM, ~8s latency). Get a free key at jina.ai for 500 RPM.
JINA_API_KEY=

# Tavily — server only, used for web search when no client sources are configured
# 1,000 free credits/month at tavily.com. Without a key, research returns no topics for unconfigured clients.
TAVILY_API_KEY=
